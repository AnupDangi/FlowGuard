    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "expr": "sum(rate(flowguard_gateway_http_requests_total[5m]))",
          "legendFormat": "gateway_rps",
          "refId": "A"
        }
      ],
      "title": "Gateway RPS",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(flowguard_gateway_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "Gateway Latency p95",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(kafka_consumergroup_lag)",
          "legendFormat": "total_lag",
          "refId": "A"
        }
      ],
      "title": "Kafka Consumer Lag",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "id": 4,
      "targets": [
        { "expr": "flowguard_bronze_orders_rows", "legendFormat": "bronze_orders", "refId": "A" },
        { "expr": "flowguard_silver_orders_rows", "legendFormat": "silver_orders", "refId": "B" },
        { "expr": "flowguard_gold_gmv_rows", "legendFormat": "gold_gmv", "refId": "C" }
      ],
      "title": "ETL Stage Rows",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "id": 5,
      "targets": [
        { "expr": "flowguard_fraud_alerts_total", "legendFormat": "fraud_alerts_total", "refId": "A" },
        { "expr": "flowguard_fraud_recent_list_len", "legendFormat": "fraud_recent_len", "refId": "B" }
      ],
      "title": "Fraud Metrics",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "id": 6,
      "targets": [
        { "expr": "probe_success{job=\"blackbox_http\",instance=\"http://host.docker.internal:8000/health\"}", "legendFormat": "gateway_health", "refId": "A" },
        { "expr": "probe_success{job=\"blackbox_http\",instance=\"http://host.docker.internal:8080/health\"}", "legendFormat": "airflow_health", "refId": "B" }
      ],
      "title": "API/DAG Health Probes",
      "type": "timeseries"
