# Environment Variables Configuration
# Copy this file to .env and update with your values

# ========== Kafka Configuration ==========
KAFKA_BOOTSTRAP_SERVERS=localhost:19092,localhost:19093,localhost:19094
KAFKA_CLIENT_ID=events-gateway

# ========== Events Gateway Configuration ==========
EVENTS_GATEWAY_HOST=0.0.0.0
EVENTS_GATEWAY_PORT=8000
EVENTS_GATEWAY_RELOAD=true
EVENTS_GATEWAY_JWT_SECRET=change_me_super_secret
EVENTS_GATEWAY_JWT_EXPIRE_MINUTES=10080

# ========== Environment ==========
ENVIRONMENT=development
LOG_LEVEL=INFO

# ========== Catalog PostgreSQL ==========
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=flowguard
POSTGRES_PASSWORD=flowguard123
POSTGRES_DB=food_catalog

# ========== Analytics PostgreSQL (Bronze/Silver/Gold) ==========
ANALYTICS_POSTGRES_HOST=localhost
ANALYTICS_POSTGRES_PORT=5434
ANALYTICS_POSTGRES_USER=flowguard
ANALYTICS_POSTGRES_PASSWORD=flowguard123
ANALYTICS_POSTGRES_DB=flowguard_analytics


# ========== Batch Processing Configuration ==========
BATCH_SIZE=100
BATCH_TIMEOUT=5.0
CONSUMER_GROUP_ID=bronze-consumer-group

# ========== Optional: Future Use ==========
# S3/MinIO Configuration
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=flowguard-data-lake
# S3_ENDPOINT_URL=http://localhost:9000

# Redis Configuration
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ========== Fraud detection job (Phase 2) ==========
# FRAUD_VELOCITY_THRESHOLD=3
# FRAUD_VELOCITY_WINDOW_MINUTES=5
# FRAUD_HIGH_VALUE_THRESHOLD=1500
# FRAUD_ALERT_COOLDOWN_SECONDS=300
